<%- include('partials/header') %>

<style>
/* Masonry Styles */
.masonry {
    column-count: 3;
    column-gap: 15px;
    margin-top: 30px;
}
.masonry-item {
    display: inline-block;
    width: 100%;
    margin-bottom: 15px;
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    cursor: pointer;
}
.masonry-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
}
.masonry-item:hover img {
    transform: scale(1.05);
}
.masonry-item .overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(0, 51, 102, 0.8);
    overflow: hidden;
    width: 100%;
    height: 0;
    transition: .5s ease;
}
.masonry-item:hover .overlay {
    height: 100%;
}
.masonry-item .text {
    color: white;
    font-size: 16px;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    width: 100%;
    opacity: 0;
    transition: opacity 0.5s 0.2s;
}
.masonry-item:hover .text {
    opacity: 1;
}

@media (max-width: 992px) { .masonry { column-count: 2; } }
@media (max-width: 576px) { .masonry { column-count: 1; } }

/* Lightbox overlay custom CSS */
.lightbox-modal { display:none; position:fixed; z-index:1050; padding-top:60px; left:0; top:0; width:100%; height:100%; overflow:auto; background-color:rgba(0,0,0,0.9); }
.lightbox-content { margin:auto; display:block; width:80%; max-width:800px; animation-name:zoom; animation-duration:0.6s; }
.lightbox-close { position:absolute; top:15px; right:35px; color:#f1f1f1; font-size:40px; font-weight:bold; transition:0.3s; cursor:pointer; }
.lightbox-close:hover { color:#bbb; text-decoration:none; cursor:pointer; }
.lightbox-caption { margin:auto; display:block; width:80%; max-width:800px;text-align:center;color:#ccc;padding:10px 0;height:150px; }
@keyframes zoom { from {transform:scale(0)} to {transform:scale(1)} }
</style>

<section class="py-5 bg-light">
    <div class="container py-4 text-center">
        <h1 class="display-5 fw-bold" style="color:var(--deep-blue);"><%= page %></h1>
    </div>
</section>

<section class="py-5 bg-white min-vh-100">
    <div class="container" data-aos="fade-up">
        
        <div class="text-center mb-4">
            <h2 class="section-title">Campus Tour & Events</h2>
            <div class="btn-group mt-3 filter-buttons" role="group">
                <button type="button" class="btn btn-outline-primary active" data-filter="all">All</button>
                <button type="button" class="btn btn-outline-primary" data-filter="campus">Campus</button>
                <button type="button" class="btn btn-outline-primary" data-filter="events">Events</button>
                <button type="button" class="btn btn-outline-primary" data-filter="labs">Labs</button>
            </div>
        </div>

        <div class="masonry">
            <% if(gallery.length > 0) { %>
                <% gallery.forEach((img, i) => { %>
                    <div class="masonry-item filter-item <%= img.category ? img.category.toLowerCase() : 'campus' %>" onclick="openLightbox('<%= img.image_url %>', '<%= img.title %>')">
                        <img src="<%= img.image_url %>" alt="<%= img.title %>">
                        <div class="overlay">
                            <div class="text text-uppercase fw-bold"><i class="fas fa-search-plus fa-2x mb-2 d-block"></i> <%= img.title || 'Image' %></div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="w-100 text-center text-muted col-12 py-5 bg-light rounded" style="grid-column: 1 / -1;">
                    <i class="fas fa-image mb-3" style="font-size:3rem; color:#ccc;"></i>
                    <h5>No images in the gallery yet.</h5>
                </div>
            <% } %>
        </div>

    </div>
</section>

<!-- Lightbox Modal -->
<div id="myLightbox" class="lightbox-modal">
  <span class="lightbox-close" onclick="closeLightbox()">&times;</span>
  <img class="lightbox-content" id="img01">
  <div id="caption" class="lightbox-caption"></div>
</div>

<script>
    // Lightbox Script
    function openLightbox(src, title) {
        var modal = document.getElementById("myLightbox");
        var modalImg = document.getElementById("img01");
        var captionText = document.getElementById("caption");
        modal.style.display = "block";
        modalImg.src = src;
        captionText.innerHTML = title;
    }
    
    function closeLightbox() {
        var modal = document.getElementById("myLightbox");
        modal.style.display = "none";
    }

    // Filter Script
    document.addEventListener('DOMContentLoaded', () => {
        const filterBtns = document.querySelectorAll('.filter-buttons .btn');
        const items = document.querySelectorAll('.filter-item');
        
        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                // remove active class
                filterBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                
                const filter = btn.getAttribute('data-filter');
                
                items.forEach(item => {
                    if (filter === 'all' || item.classList.contains(filter)) {
                        item.style.display = 'inline-block';
                    } else {
                        item.style.display = 'none';
                    }
                });
            });
        });
    });
</script>

<%- include('partials/footer') %>
