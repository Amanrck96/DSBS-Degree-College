<%- include('partials/header') %>

<section class="py-5 bg-light">
    <div class="container py-4 text-center">
        <h1 class="display-5 fw-bold" style="color:var(--deep-blue);"><%= page %></h1>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container">
        <h2 class="section-title text-center mb-5" data-aos="fade-up">Our Academic Offerings</h2>
        <div class="row g-4">
            <!-- Course 1 -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="card h-100 shadow-sm border-0 hover-zoom">
                    <img src="https://via.placeholder.com/400x250?text=BCA" class="card-img-top" alt="BCA">
                    <div class="card-body p-4 bg-light">
                        <h4 class="card-title fw-bold text-dark">Bachelor of Computer Applications (BCA)</h4>
                        <p class="text-muted">3-Year Undergraduate Program designed to provide a solid foundation in computer science and robust programming expertise.</p>
                        <a href="/admissions" class="btn btn-primary-custom w-100 mt-3">Apply Now</a>
                    </div>
                </div>
            </div>
            <!-- Course 2 -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="card h-100 shadow-sm border-0 hover-zoom">
                    <img src="https://via.placeholder.com/400x250?text=BBA" class="card-img-top" alt="BBA">
                    <div class="card-body p-4 bg-light">
                        <h4 class="card-title fw-bold text-dark">Bachelor of Business Admin (BBA)</h4>
                        <p class="text-muted">A dynamic 3-year program covering management, economics, accounting, and organizational behavior.</p>
                        <a href="/admissions" class="btn btn-primary-custom w-100 mt-3">Apply Now</a>
                    </div>
                </div>
            </div>
            <!-- Course 3 -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="card h-100 shadow-sm border-0 hover-zoom">
                    <img src="https://via.placeholder.com/400x250?text=B.Com" class="card-img-top" alt="B.Com">
                    <div class="card-body p-4 bg-light">
                        <h4 class="card-title fw-bold text-dark">Bachelor of Commerce (B.Com)</h4>
                        <p class="text-muted">Gain in-depth knowledge of business processes, auditing, corporate taxation, and financial markets over 3 years.</p>
                        <a href="/admissions" class="btn btn-primary-custom w-100 mt-3">Apply Now</a>
                    </div>
                </div>
            </div>
            <!-- Course 4: PGDM -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="card h-100 shadow-sm border-0 hover-zoom">
                    <img src="https://via.placeholder.com/400x250?text=PGDM" class="card-img-top" alt="PGDM">
                    <div class="card-body p-4 bg-light">
                        <h4 class="card-title fw-bold text-dark">Post Grad Diploma in Management (PGDM)</h4>
                        <p class="text-muted">A rigorous 2-year postgraduate program equipping future leaders with strategic thinking and diverse global management skills.</p>
                        <a href="/admissions" class="btn btn-primary-custom w-100 mt-3">Apply Now</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
