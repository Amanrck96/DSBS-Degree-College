<%- include('partials/header') %>

<section class="py-5 bg-light">
    <div class="container py-4 text-center">
        <h1 class="display-5 fw-bold" style="color:var(--deep-blue);"><%= page %></h1>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container" data-aos="fade-up">
        <div class="row g-5">
            <!-- Contact Info -->
            <div class="col-lg-5">
                <h2 class="mb-4 fw-bold" style="color:var(--deep-blue);">Get In Touch</h2>
                <p class="text-muted mb-5">Have questions about admissions, courses, or events? Feel free to reach out to our dedicated support team using the contact information below or by filling out the form.</p>
                
                <div class="d-flex align-items-center mb-4">
                    <div class="icon bg-light text-primary rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width:60px; height:60px; font-size:24px;">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1">Campus Location</h5>
                        <p class="text-muted mb-0">DSBS Degree College, Shavige Malleshwara Hills, <br>Kumaraswamy Layout, Bengaluru - 560078</p>
                    </div>
                </div>

                <div class="d-flex align-items-center mb-4">
                    <div class="icon bg-light text-success rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width:60px; height:60px; font-size:24px;">
                        <i class="fas fa-phone-alt"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1">Phone Numbers</h5>
                        <p class="text-muted mb-0">Landline: xyxyxyx<br>Mobile: xyxyxyx</p>
                    </div>
                </div>

                <div class="d-flex align-items-center mb-4">
                    <div class="icon bg-light text-warning rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width:60px; height:60px; font-size:24px;">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1">Email Address</h5>
                        <p class="text-muted mb-0">xyxyxyx</p>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="col-lg-7" data-aos="slide-left">
                <div class="card border-0 shadow-lg" style="border-radius:15px;">
                    <div class="card-body p-5">
                        <h3 class="fw-bold mb-4">Send us a Message</h3>
                        <form action="#" method="POST" onsubmit="event.preventDefault(); alert('Thank you! Your message has been sent successfully.'); this.reset();">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Full Name</label>
                                    <input type="text" class="form-control bg-light" placeholder="Your Name" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Email Address</label>
                                    <input type="email" class="form-control bg-light" placeholder="name@example.com" required>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold">Phone Number</label>
                                    <input type="tel" class="form-control bg-light" placeholder="Your Mobile Number" required>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold">Message Subject</label>
                                    <input type="text" class="form-control bg-light" placeholder="What is this regarding?" required>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold">Your Message</label>
                                    <textarea class="form-control bg-light" rows="5" placeholder="Write your message here..." required></textarea>
                                </div>
                                <div class="col-12 mt-4 text-end">
                                    <button type="submit" class="btn btn-primary-custom px-5 py-2 w-100 fw-bold shadow"><i class="fas fa-paper-plane me-2"></i> Send Message</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Google Map Section Full Width -->
<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15555.433285702175!2d77.5623075!3d12.9065471!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bae150d7349a72b%3A0xf3d03ea1e1dd3d46!2sDayananda%20Sagar%20Institutions!5e0!3m2!1sen!2sin!4v1689234850020!5m2!1sen!2sin" width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy"></iframe>

<%- include('partials/footer') %>
